# Toggle Supabase-backed persistence on or off.
VITE_FEATURE_SUPABASE_PERSISTENCE_ENABLED=false

# Supabase configuration used when the feature flag is enabled.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Enable a built-in demo user for local development.
VITE_FEATURE_DUMMY_AUTH_ENABLED=false
VITE_DUMMY_AUTH_USER_ID=dummy-user
VITE_DUMMY_AUTH_USER_NAME=Demo User
VITE_DUMMY_AUTH_USER_SLUG=dummy-user
VITE_DUMMY_AUTH_USER_ROLE=client
