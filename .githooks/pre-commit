#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$ROOT_DIR"

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required for pre-commit checks." >&2
  exit 1
fi

npm run format:changed

# Keep ordinary commits fast by default. The heavier web verification pass is
# opt-in so local commits are not blocked by lint/test/build work every time.
# Set PRECOMMIT_VERIFY=1 before committing if you want that extra check.
if [ "${PRECOMMIT_VERIFY:-0}" = "1" ]; then
  echo "Running the heavier pre-commit verification flow."
  npm run verify:precommit
else
  echo "Skipping the heavier pre-commit verification flow. Set PRECOMMIT_VERIFY=1 to run it."
fi
