#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$ROOT_DIR"

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required for pre-commit checks." >&2
  exit 1
fi

npm run format:changed

# Intentionally skip Knip in pre-commit checks; this hook runs formatting and
# the faster pre-commit verification flow without the full Knip pass.
# npm run verify
npm run verify:precommit
